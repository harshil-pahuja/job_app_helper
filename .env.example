# Required backend secret. Keep this server-side only.
OPENAI_API_KEY=sk-...

# Local frontend-to-backend URL. In deployment, set this in the frontend host
# to your deployed backend URL, for example:
# VITE_API_BASE=https://jobmigo-api.onrender.com
VITE_API_BASE=http://localhost:8000

# Backend CORS allowlist. Leave blank locally. After deploying the frontend,
# set this in the backend host to the deployed frontend URL, for example:
# FRONTEND_URL=https://jobmigo.vercel.app
FRONTEND_URL=

# Use local embeddings to reduce OpenAI cost and rate-limit pressure.
RAG_EMBEDDING_BACKEND=huggingface

# Keep raw/private debug logs off in production and normal local use.
DEBUG_PRIVACY_LOGS=false

# Keep LangSmith/LangChain tracing off unless you intentionally want traces.
# Traces can include prompt content.
LANGSMITH_TRACING=false
LANGCHAIN_TRACING_V2=false
