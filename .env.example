# ─── Required ──────────────────────────────────────────────────────────────
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
# The app uses GPT-4o for resume feedback and extraction.
OPENAI_API_KEY=sk-...

# ─── Optional (production only) ────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# Localhost dev origins (5173, 3000, 3001) are always allowed — only set this
# in production once your frontend has a real URL. Multiple origins OK.
# Example: FRONTEND_URL=https://jobmigo.vercel.app,https://staging.jobmigo.app
FRONTEND_URL=

# ─── Optional (advanced) ───────────────────────────────────────────────────
# Which embedding model the RAG system uses. Defaults to "auto":
#   - "openai"      : OpenAI embeddings (costs money, higher quality)
#   - "huggingface" : local sentence-transformers (free, slower first run)
#   - "auto"        : openai if OPENAI_API_KEY is set, else huggingface
RAG_EMBEDDING_BACKEND=auto
